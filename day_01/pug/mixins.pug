mixin tourItem(image, price, title, review, countReview, duration, tourPrice)
    .tour-item
        .tour-top
            img.tour-image(src= image, alt='bali')
            span.tour-price= price
        .tour-content
            h3.tour-title= title
            .tour-ratting 
                .tour-review 
                    .tour-star
                        img(src="./image/Shape.png", alt="tour-ratting")
                    span.tour-review-count= review 
                        |  (#{countReview} review)
                span.tour-duration Duration: #{duration} hours
            a.tour-button(href='#' target='_blank' rel='noopener noreferre') Tours Price $#{tourPrice}

mixin popuplarItem 
    .popuplar-item
        .popuplar-image
            .popuplar-overplay
            img.popuplar-img(src="https://images.unsplash.com/photo-1501785888041-af3ef285b470?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=1170&q=80", alt="") 
            span.popuplar-label Must See
        .popuplar-content
            span.popuplar-time Sep 28 10:00 AM - 1:00 PM
            h3.popuplar-title The Grand Palace
            .popuplar-review 
                .popuplar-star
                    img(src="./image/Shape.png", alt="star")
                span.popuplar-review-count 4.8 (12 reviews)

